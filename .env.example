# ─────────────────────────────────────────────
#  Variáveis de ambiente — Newsletter JT Esportes
#  Copie este arquivo para .env e preencha os valores
#  NÃO comite o arquivo .env no Git
# ─────────────────────────────────────────────

# Chave da API do Claude (Anthropic)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Configurações SMTP ──────────────────────
# Para Gmail: crie uma "Senha de app" em myaccount.google.com/security
# (requer verificação em duas etapas ativada)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# ── E-mails ─────────────────────────────────
# Remetente (normalmente igual ao SMTP_USER)
FROM_EMAIL=seu_email@gmail.com

# Destinatário da newsletter
TO_EMAIL=jtcarvalho.seg@gmail.com
